#!/usr/bin/env python3
"""Quick system info — like neofetch but 50 lines."""

import platform
import os
import shutil
import subprocess
import sys
from datetime import datetime


def run(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, stderr=subprocess.DEVNULL).decode().strip()
    except Exception:
        return "unknown"


def get_uptime():
    try:
        with open("/proc/uptime") as f:
            seconds = int(float(f.readline().split()[0]))
        days, rem = divmod(seconds, 86400)
        hours, rem = divmod(rem, 3600)
        mins = rem // 60
        parts = []
        if days:
            parts.append(f"{days}d")
        if hours:
            parts.append(f"{hours}h")
        parts.append(f"{mins}m")
        return " ".join(parts)
    except Exception:
        return "unknown"


def get_shell():
    return os.environ.get("SHELL", os.environ.get("TERM_PROGRAM", "unknown")).split("/")[-1]


def main():
    user = os.environ.get("USER", os.environ.get("LOGNAME", "unknown"))
    hostname = platform.node()
    kernel = platform.release()
    os_name = f"{platform.system()} {platform.release()}"
    arch = platform.machine()
    shell = get_shell()
    uptime = get_uptime()
    cpu = run("lscpu | grep 'Model name' | cut -d: -f2 | xargs || echo unknown")
    mem = run("free -h | awk '/^Mem:/ {print $3 \"/\" $2}' || echo unknown")
    disk = run("df -h / | awk 'NR==2 {print $3 \"/\" $2 \" (\" $5 \")\"}' || echo unknown")
    packages = run(
        "dpkg -l 2>/dev/null | grep '^ii' | wc -l; "
        "snap list 2>/dev/null | tail -n +2 | wc -l"
    ).replace("\n", " deb, ") + " snap"

    width = 40
    print(f"  {user}@{hostname}".ljust(width))
    print("-" * width)
    print(f"  OS:        {os_name}")
    print(f"  Kernel:    {kernel}")
    print(f"  Arch:      {arch}")
    print(f"  Uptime:    {uptime}")
    print(f"  Shell:     {shell}")
    print(f"  CPU:       {cpu[:60]}")
    print(f"  Memory:    {mem}")
    print(f"  Disk (/):  {disk}")
    print(f"  Packages:  {packages}")
    print("-" * width)
    colors = ["\033[4" + str(i) + "m  \033[0m" for i in range(8)]
    print("  " + "".join(colors))


if __name__ == "__main__":
    main()
